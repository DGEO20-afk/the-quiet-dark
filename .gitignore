# =============================================
# THE QUIET DARK — .gitignore
# Unity + Blender + Windows
# =============================================

# ── UNITY GENERATED ──────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emory[Cc]aptures/
[Rr]ecordings/

# Unity auto-generated meta files für ignoriete Dateien
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity Crash Reports
crashlytics-build.properties
sysinfo.txt

# Visual Studio / Rider
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.idea/
*.rider.dotSettings.user

# ── BLENDER ───────────────────────────────────
# Blender auto-saves und temporäre Dateien
*.blend1
*.blend2
*.blend3
*.blend4
*.blend5
__pycache__/
*.pyc

# ── BETRIEBSSYSTEM ───────────────────────────
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS (falls Kollegen Mac nutzen)
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── EXPORTS / BUILDS ─────────────────────────
# Fertige Builds nicht tracken (zu groß)
Builds/
Build/
*.exe
*.app
*.apk

# ── LOGS ─────────────────────────────────────
*.log
npm-debug.log*

# ── SONSTIGES ────────────────────────────────
*.tmp
*.bak
*.swp
*~
